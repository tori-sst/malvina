---
interface Props {
	title?: string;
	description?: string;
}

const { 
	title = "Конный клуб «Мальвина»", 
	description = "Уютный конный клуб «Мальвина». Обучение верховой езде для детей и взрослых, прогулки на лошадях, фотосессии и аренда денников." 
} = Astro.props;
---
<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />

		<title>{title}</title>
		<meta name="description" content={description} />
	</head>
	<body>
		<slot />
	</body>
</html>

<style>
	html,
	body {
		margin: 0;
		width: 100%;
		height: 100%;
	}
</style>
