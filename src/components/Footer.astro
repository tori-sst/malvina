---
import '../styles/global.css'
import { Icon } from 'astro-icon/components'
---
<footer class="bg-brown w-full pt-16 pb-6 px-4 md:px-12 text-sand-light border-t border-sand-dark/20">
  <div class="max-w-6xl mx-auto flex flex-col gap-12">
    
    <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-4 gap-8 items-start text-center sm:text-left">
      
      <div class="flex flex-col items-center sm:items-start gap-4">
        
        <img 
          src="/malvina/img/logo_brown.png" 
          alt="Мальвина" 
          class="h-24 w-auto object-contain brightness-110"
          loading="lazy" 
          decoding="async"  
        />
        <div class="font-vintage text-2xl tracking-wide text-sand-light select-none">
          Мальвина
        </div>
        <div class="flex gap-4 mt-1">
          <a 
            href="https://vk.com" 
            target="_blank" 
            class="w-10 h-10 rounded-full bg-sand-light/10 flex items-center justify-center text-sand-light hover:bg-orange hover:text-white transition-all duration-200 active:scale-90"
            aria-label="Мы в ВКонтакте"
          >
             <Icon name="ri:vk-fill" class="w-5 h-5" />
          </a>
          <a 
            href="https://t.me" 
            target="_blank" 
            class="w-10 h-10 rounded-full bg-sand-light/10 flex items-center justify-center text-sand-light hover:bg-orange hover:text-white transition-all duration-200 active:scale-90"
            aria-label="Мы в Telegram"
          >
            <Icon name="lucide:send" class="w-5 h-5" />
          </a>
        </div>
      </div>

      <div class="flex flex-col gap-2 font-sans text-base md:text-lg pt-2">
        <a href="#about" class="hover:text-sand-dark transition-colors duration-200">О нас</a>
        <a href="#gallery" class="hover:text-sand-dark transition-colors duration-200">Фотогалерея</a>
        <a href="#booking" class="hover:text-sand-dark transition-colors duration-200">Бронь</a>
        <a href="#reviews" class="hover:text-sand-dark transition-colors duration-200">Отзывы</a>
      </div>

      <div class="flex flex-col gap-4 font-sans pt-2">
        <a 
          href="tel:+79999999999" 
          class="text-xl font-handwritten hover:text-orange transition-colors duration-200 tracking-wide"
        >
          +7 999 999-99-99
        </a>
        <div class="text-sm text-sand-light/80 space-y-2 leading-relaxed">
          <p> Стерлибашевская улица, 65, Уфа, Республика Башкортостан, 450095</p>
          <p> р-н Уфимский, Мелькомбинат 43</p>
        </div>
      </div>

      <div 
        id="yandex-map"
        class="w-full aspect-video sm:aspect-square md:h-36 rounded-2xl overflow-hidden shadow-xl border border-sand-light/10"
        style="filter: grayscale(0.2) contrast(1.1);"
      >
      </div>

    </div>

    <div class="w-full h-px bg-sand-light/10"></div>

    <p class="text-center font-serif text-sm tracking-widest text-sand-light/50">
       &copy; 2026 ООО "Мальвина"
    </p>

  </div>
</footer>

<script is:inline src="https://api-maps.yandex.ru/2.1/?lang=ru_RU&apikey=813acc6e-517c-4d01-8b5d-352491d48b2b" type="text/javascript"></script>
<script>
  // Функция инициализации карты
  function initMap() {
    const mapContainer = document.getElementById('yandex-map');
    
    // Проверяем, есть ли контейнер на странице и загружен ли API Яндекса
    if (mapContainer && typeof ymaps !== 'undefined') {
      ymaps.ready(() => {
        const coordinates = [54.704659, 55.823721];
        
        const map = new ymaps.Map('yandex-map', {
          center: coordinates,
          zoom: 14,
          // Оставляем только нужные элементы управления, чтобы не перегружать маленькую карту
          controls: ['zoomControl'] 
        });

        // Добавляем маркер (геообъект) на карту
        const placemark = new ymaps.Placemark(coordinates, {
          hintContent: 'ООО "Мальвина"',
          balloonContent: 'Мальвина'
        }, {
          preset: 'islands#orangeDotIcon' // Стилизуем маркер под ваш оранжевый акцент
        });

        map.geoObjects.add(placemark);
      });
    }
  }

  // Запуск при первой загрузке страницы
  window.addEventListener('DOMContentLoaded', initMap);
  
  // Если вы используете Astro View Transitions, раскомментируйте строку ниже:
  // document.addEventListener('astro:page-load', initMap);
</script>