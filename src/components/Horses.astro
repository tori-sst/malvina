---
import '../styles/global.css'
import { horses } from '../data/horses';
---
<section id="horses" class="bg-green w-full pt-20 pb-48 md:pb-60 px-4 md:px-12 relative z-10">
  <div class="max-w-6xl mx-auto">
    
    <h2 class="font-vintage text-sand-light text-4xl md:text-5xl text-center mb-16 tracking-wide">
      Наши любимцы
    </h2>

    <div class="flex flex-col gap-12 md:gap-8 relative">
      
      {horses.map((horse, index) => {
        const isEven = index % 2 === 0;
        
        return (
          <div class={`flex flex-col md:flex-row items-center gap-6 md:gap-12 w-full ${isEven ? '' : 'md:flex-row-reverse'}`}>
            
            <div class="w-64 h-64 md:w-72 md:h-72 rounded-full overflow-hidden border-4 border-sand-dark/30 shadow-xl shrink-0">
              <img 
                src={horse.img} 
                alt={horse.name} 
                class="w-full h-full object-cover"
                loading="lazy" 
                decoding="async"
              />
            </div>

            
            <div class={`bg-sand-light/15 border border-sand-dark/20 p-6 md:p-8 rounded-3xl backdrop-blur-sm max-w-2xl grow shadow-md ${isEven ? 'text-left' : 'text-left md:text-right'}`}>
              
              <h3 class="font-vintage text-sand-light text-xl md:text-3xl mb-3 tracking-wide">
                {horse.name}
              </h3>
              
              <p class="font-sans text-sand-light/90 text-base md:text-lg leading-relaxed font-light">
                {horse.description}
              </p>
              
            </div>

          </div>
        );
      })}

    </div>
  </div>
</section>