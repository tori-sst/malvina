---
import '../styles/global.css';
import { reviews } from '../data/comments';
---
<section id="reviews" class="bg-green w-full py-20 px-4 md:px-12">
  <div class="max-w-4xl mx-auto">
    
    <h2 class="font-vintage text-sand-light text-4xl md:text-5xl text-center mb-12 tracking-wide">
      Нас выбирают
    </h2>

    <div class="flex flex-col gap-6">
      {reviews.map((review) => (
        <div class="bg-sand-light/10 border border-sand-dark/20 p-6 md:p-8 rounded-3xl flex flex-col sm:flex-row gap-6 items-start shadow-md">
          
          <div class="w-24 h-24 sm:w-28 sm:h-28 rounded-2xl overflow-hidden shrink-0 border border-sand-dark/30 shadow-inner">
            <img 
              src={review.avatar} 
              alt={review.name} 
              class="w-full h-full object-cover"
              loading="lazy" 
              decoding="async"
            />
          </div>

          <div class="flex flex-col gap-2">
            <h3 class="font-vintage text-sand-light text-2xl tracking-wide">
              {review.name}
            </h3>
            <p class="font-sans text-sand-light/90 text-sm md:text-base leading-relaxed font-light">
              {review.text}
            </p>
          </div>

        </div>
      ))}
    </div>

  </div>
</section>