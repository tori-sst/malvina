---
import '../styles/global.css'
import Button from '../ui/button.astro'
---
<header class="bg-brown w-full py-4 px-4 md:px-12 relative z-50">
  <div class="max-w-6xl mx-auto flex justify-between items-center w-full">
    
    <a href="/" class="flex items-center group">
      <img 
        src="/malvina/img/logo.jpg" 
        alt="Конный клуб Мальвина" 
        class="h-12 md:h-16 w-auto object-contain"
        loading="lazy" 
        decoding="async"
      />
    </a>

    <nav class="hidden md:flex flex-wrap justify-center gap-x-8 gap-y-2 text-sand-light font-sans text-lg md:text-xl font-medium tracking-wide">
      <a href="#services" class="hover:text-sand-dark transition-colors duration-200">Услуги</a>
      <a href="#booking" class="hover:text-sand-dark transition-colors duration-200">Бронь</a>
      <a href="#gallery" class="hover:text-sand-dark transition-colors duration-200">Фотогалерея</a>
      <a href="#reviews" class="hover:text-sand-dark transition-colors duration-200">Отзывы</a>
    </nav>

    <button id="burger-btn" class="md:hidden text-orange p-1 cursor-pointer select-none" aria-label="Открыть меню">
      <svg class="w-7 h-7 stroke-current" viewBox="0 0 24 24" fill="none" stroke-width="2.5" stroke-linecap="round">
        <line x1="3" y1="6" x2="21" y2="6"></line>
        <line x1="3" y1="12" x2="21" y2="12"></line>
        <line x1="3" y1="18" x2="21" y2="18"></line>
      </svg>
    </button>

    <div class="hidden md:flex flex-col items-end gap-2">
      <a 
        href="tel:+79999999999" 
        class="font-handwritten text-sand-light text-2xl md:text-3xl tracking-wider hover:text-sand-dark transition-colors duration-200 leading-none"
      >
        +7 999 999-99-99
      </a>
      <a href="#booking" class="w-full">
        <Button type="button">Записаться</Button>
      </a>
    </div>

  </div>

  <div id="mobile-menu" class="hidden flex-col items-center gap-3 mt-3 pt-3 border-t border-sand-light/10 w-full text-center animate-fade-in">
    
    <nav class="flex flex-col gap-2 text-sand-light font-sans text-lg font-medium tracking-wide mb-1 w-full">
      <a href="#services" class="mobile-link hover:text-sand-dark py-1 transition-colors">Услуги</a>
      <a href="#booking" class="mobile-link hover:text-sand-dark py-1 transition-colors">Бронь</a>
      <a href="#gallery" class="mobile-link hover:text-sand-dark py-1 transition-colors">Фотогалерея</a>
      <a href="#reviews" class="mobile-link hover:text-sand-dark py-1 transition-colors">Отзывы</a>
    </nav>

    <a 
      href="tel:+79999999999" 
      class="font-handwritten text-sand-light text-2xl tracking-wider hover:text-sand-dark transition-colors duration-200 leading-none mt-1"
    >
      +7 999 999-99-99
    </a>
    <a href="#booking" class="mobile-link w-full max-w-[240px] text-sm mt-1">
      <Button type="button" class="py-2.5 text-base">Записаться</Button>
    </a>
  </div>
</header>

<script>
  const burgerBtn = document.getElementById('burger-btn');
  const mobileMenu = document.getElementById('mobile-menu');
  const mobileLinks = document.querySelectorAll('.mobile-link');

  if (burgerBtn && mobileMenu) {
    const toggleMenu = () => {
      if (mobileMenu.classList.contains('hidden')) {
        mobileMenu.classList.remove('hidden');
        mobileMenu.classList.add('flex');
      } else {
        mobileMenu.classList.remove('flex');
        mobileMenu.classList.add('hidden');
      }
    };

    burgerBtn.addEventListener('click', toggleMenu);

    mobileLinks.forEach(link => {
      link.addEventListener('click', () => {
        mobileMenu.classList.remove('flex');
        mobileMenu.classList.add('hidden');
      });
    });
  }
</script>
